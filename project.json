{
  "$schema": "./node_modules/nx/schemas/project-schema.json",
  "name": "root",
  "projectType": "library",
  "targets": {
    "audit": {
      "command": "pnpm audit --ignore-registry-errors",
      "inputs": ["{projectRoot}/pnpm-lock.yaml"],
      "metadata": {
        "description": "Check for security vulnerabilities in your dependencies",
        "technologies": ["node"]
      }
    },
    "test:scripts": {
      "command": "node --test .github/scripts/__tests__/check-updates.test.ts",
      "cache": true,
      "inputs": ["{workspaceRoot}/.github/scripts/**/*.ts"],
      "metadata": {
        "description": "Run CI script tests",
        "technologies": ["node"]
      }
    },
    "typecheck": {
      "command": "tsc --noEmit",
      "cache": true,
      "inputs": [
        "{workspaceRoot}/tools/**/*.ts",
        "{workspaceRoot}/.github/scripts/**/*.ts",
        "{workspaceRoot}/tsconfig.json"
      ],
      "metadata": {
        "description": "Typecheck hand-written TypeScript",
        "technologies": ["typescript"]
      }
    },
    "check": {
      "dependsOn": [
        "build",
        "test:scripts",
        "typecheck",
        "syncpack:format:check",
        "syncpack:lint",
        "prettier:check"
      ]
    },
    "fix": {
      "dependsOn": ["syncpack:format", "prettier:write"]
    },
    "syncpack:fix": {
      "command": "syncpack fix",
      "inputs": ["syncpack"],
      "cache": true,
      "metadata": {
        "description": "Fix every auto-fixable issue found by `syncpack lint`.",
        "technologies": ["node"]
      }
    },
    "syncpack:format": {
      "command": "syncpack format",
      "inputs": ["syncpack"],
      "cache": true,
      "dependsOn": ["syncpack:fix"],
      "metadata": {
        "description": "Sort package.json fields into a predictable order and nested fields alphabetically.",
        "technologies": ["node"]
      }
    },
    "syncpack:format:check": {
      "command": "syncpack format --check",
      "inputs": ["syncpack"],
      "cache": true,
      "options": {
        "source": "{projectRoot}/package.json"
      },
      "metadata": {
        "description": "Lint formatting instead of fixing it and exit with a status code of 1 if issues are found.",
        "technologies": ["node"]
      }
    },
    "syncpack:lint": {
      "command": "syncpack lint",
      "inputs": ["syncpack"],
      "cache": true,
      "metadata": {
        "description": "Lint all versions and ranges and exit with `0` or `1` based on whether all files match your Syncpack configuration file.",
        "technologies": ["node"]
      }
    },
    "prettier:check": {
      "inputs": ["prettier:root"],
      "options": {
        "ignore-path": "root.prettierignore"
      }
    },
    "prettier:write": {
      "inputs": ["prettier:root"],
      "options": {
        "ignore-path": "root.prettierignore"
      }
    }
  }
}
