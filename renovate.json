{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "config:js-app",
    ":automergePr",
    ":automergeMinor",
    ":automergeTypes",
    "security:minimumReleaseAgeNpm",
    "group:definitelyTyped",
    "schedule:nonOfficeHours",
    ":separateMultipleMajorReleases",
    "schedule:automergeNonOfficeHours",
    ":automergeRequireAllStatusChecks"
  ],
  "postUpdateOptions": ["pnpmDedupe"],
  "timezone": "Asia/Ho_Chi_Minh",
  "packageRules": [
    {
      "groupName": "fumadocs monorepo",
      "matchPackageNames": ["/^fumadocs-/"],
      "matchUpdateTypes": ["digest", "patch", "minor", "major"]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track AikidoSec/safe-chain installer URL in workflows",
      "managerFilePatterns": ["/^\\.github/workflows/.*\\.ya?ml$/"],
      "matchStrings": [
        "AikidoSec/safe-chain/releases/download/(?<currentValue>[^/]+)/install-safe-chain\\.sh"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "AikidoSec/safe-chain"
    },
    {
      "customType": "regex",
      "description": "Track pinned npm CLI version in workflow run blocks",
      "managerFilePatterns": ["/^\\.github/workflows/.*\\.ya?ml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)\\s+run: npm install -g npm@(?<currentValue>\\S+)"
      ]
    }
  ]
}
