{
    "compilerOptions": {
        // Output
        "outDir": "bin",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "stripInternal": true,
        // Environment
        "target": "ES2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "moduleDetection": "force",
        "types": ["node"],
        // Type Checking
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "skipLibCheck": true
    },
    "files": [
        "collector.ts",
        "config/index.ts",
        "config/vars.ts",
        "connection.ts",
        "dashboard.ts",
        "dashboardAlert.ts",
        "dashboardChart.ts",
        "dashboardGroup.ts",
        "dashboardSection.ts",
        "errorsApplication.ts",
        "errorsApplicationGroup.ts",
        "exploration.ts",
        "explorationAlert.ts",
        "explorationGroup.ts",
        "getCollector.ts",
        "getConnection.ts",
        "getDashboard.ts",
        "getDashboardAlert.ts",
        "getDashboardChart.ts",
        "getDashboardGroup.ts",
        "getDashboardSection.ts",
        "getDashboardTemplate.ts",
        "getErrorsApplication.ts",
        "getErrorsApplicationGroup.ts",
        "getExploration.ts",
        "getExplorationAlert.ts",
        "getExplorationGroup.ts",
        "getMetric.ts",
        "getSource.ts",
        "getSourceGroup.ts",
        "getWarehouseEmbedding.ts",
        "getWarehouseSource.ts",
        "getWarehouseSourceGroup.ts",
        "index.ts",
        "metric.ts",
        "provider.ts",
        "source.ts",
        "sourceGroup.ts",
        "types/index.ts",
        "types/input.ts",
        "types/output.ts",
        "utilities.ts",
        "warehouseEmbedding.ts",
        "warehouseSource.ts",
        "warehouseSourceGroup.ts",
        "warehouseTimeSeries.ts"
    ]
}
