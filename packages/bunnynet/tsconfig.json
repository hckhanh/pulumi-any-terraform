{
    "compilerOptions": {
        // Output
        "outDir": "bin",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "stripInternal": true,
        // Environment
        "target": "ES2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "moduleDetection": "force",
        "types": ["node"],
        // Type Checking
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "skipLibCheck": true
    },
    "files": [
        "computeContainerApp.ts",
        "computeContainerImageregistry.ts",
        "computeScript.ts",
        "computeScriptSecret.ts",
        "computeScriptVariable.ts",
        "config/index.ts",
        "config/vars.ts",
        "database.ts",
        "dnsRecord.ts",
        "dnsScript.ts",
        "dnsScriptVariable.ts",
        "dnsZone.ts",
        "getComputeContainerAppContainer.ts",
        "getComputeContainerAppContainerEndpoint.ts",
        "getComputeContainerImageregistry.ts",
        "getDnsRecord.ts",
        "getDnsZone.ts",
        "getPullzone.ts",
        "getPullzoneAccessLists.ts",
        "getRegion.ts",
        "getVideoLanguage.ts",
        "index.ts",
        "provider.ts",
        "pullzone.ts",
        "pullzoneAccessList.ts",
        "pullzoneEdgerule.ts",
        "pullzoneHostname.ts",
        "pullzoneOptimizerClass.ts",
        "pullzoneRatelimitRule.ts",
        "pullzoneShield.ts",
        "pullzoneWafRule.ts",
        "storageFile.ts",
        "storageZone.ts",
        "streamCollection.ts",
        "streamLibrary.ts",
        "streamVideo.ts",
        "types/index.ts",
        "types/input.ts",
        "types/output.ts",
        "utilities.ts"
    ]
}
