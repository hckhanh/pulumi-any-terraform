{
  "name": "pulumi-openfga",
  "description": "A Pulumi provider for managing OpenFGA fine-grained authorization (ReBAC) with support for stores, authorization models, and relationship tuples, dynamically bridged from the Terraform OpenFGA provider.",
  "version": "0.5.2",
  "homepage": "https://pulumi.khanh.id/docs/providers/openfga",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hckhanh/pulumi-any-terraform.git",
    "directory": "packages/openfga"
  },
  "private": false,
  "sideEffects": false,
  "main": "./bin/index.js",
  "module": "./bin/index.js",
  "types": "./bin/index.d.ts",
  "exports": {
    ".": "./bin/index.js",
    "./package.json": "./package.json"
  },
  "dependencies": {
    "async-mutex": "0.5.0"
  },
  "devDependencies": {
    "@pulumi/pulumi": "3.232.0",
    "@types/node": "24.12.2",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "@pulumi/pulumi": ">=3.190.0 <4"
  },
  "files": [
    "bin",
    "README.md"
  ],
  "keywords": [
    "pulumi",
    "openfga",
    "authorization",
    "fine-grained-authorization",
    "rebac",
    "zanzibar",
    "permissions",
    "access-control",
    "relationship-tuples",
    "authorization-model",
    "terraform",
    "provider",
    "infrastructure",
    "devops"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "pulumi": {
    "resource": true,
    "name": "terraform-provider",
    "version": "1.1.1",
    "parameterization": {
      "name": "openfga",
      "version": "0.5.1",
      "value": "eyJyZW1vdGUiOnsidXJsIjoicmVnaXN0cnkub3BlbnRvZnUub3JnL29wZW5mZ2Evb3BlbmZnYSIsInZlcnNpb24iOiIwLjUuMSJ9fQ=="
    }
  }
}
