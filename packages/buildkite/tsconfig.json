{
    "compilerOptions": {
        // Output
        "outDir": "bin",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "stripInternal": true,
        // Environment
        "target": "ES2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "moduleDetection": "force",
        "types": ["node"],
        // Type Checking
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "skipLibCheck": true
    },
    "files": [
        "agentToken.ts",
        "cluster.ts",
        "clusterAgentToken.ts",
        "clusterDefaultQueue.ts",
        "clusterMaintainer.ts",
        "clusterQueue.ts",
        "clusterSecret.ts",
        "config/index.ts",
        "config/vars.ts",
        "getCluster.ts",
        "getClusters.ts",
        "getMeta.ts",
        "getOrganization.ts",
        "getOrganizationMember.ts",
        "getOrganizationMembers.ts",
        "getOrganizationRule.ts",
        "getPipeline.ts",
        "getPipelineTemplate.ts",
        "getPortal.ts",
        "getPortals.ts",
        "getRegistry.ts",
        "getSignedPipelineSteps.ts",
        "getTeam.ts",
        "getTeams.ts",
        "getTestSuite.ts",
        "index.ts",
        "organization.ts",
        "organizationBanner.ts",
        "organizationRule.ts",
        "pipeline.ts",
        "pipelineSchedule.ts",
        "pipelineTeam.ts",
        "pipelineTemplate.ts",
        "pipelineWebhook.ts",
        "portal.ts",
        "provider.ts",
        "registry.ts",
        "team.ts",
        "teamMember.ts",
        "testSuite.ts",
        "testSuiteTeam.ts",
        "types/index.ts",
        "types/input.ts",
        "types/output.ts",
        "utilities.ts"
    ]
}
